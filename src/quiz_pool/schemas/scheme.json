{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/quiz-pool.schema.json",
  "title": "Quiz Pool",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "learningObjectives", "questions"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Name of the quiz pool"
    },
    "description": {
      "type": "string",
      "description": "Optional description of the quiz pool"
    },
    "learningObjectives": {
      "type": "array",
      "description": "Master list of one or more learning objectives",
      "items": {
        "$ref": "#/$defs/learningObjective"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "learningObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^LO[1-9][0-9]*$"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "question",
        "choices",
        "shuffleChoices",
        "learningObjectiveIds",
        "correctAnswers",
        "locations",
        "points",
        "difficulty"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the question"
        },
        "question": {
          "type": "string",
          "description": "Question text. Inline LaTeX is supported with [math]...[/math]."
        },
        "choices": {
          "type": "array",
          "description": "Contiguous answer choices labeled from A up to at most E",
          "minItems": 2,
          "maxItems": 5,
          "prefixItems": [
            {
              "$ref": "#/$defs/choiceA"
            },
            {
              "$ref": "#/$defs/choiceB"
            },
            {
              "$ref": "#/$defs/choiceC"
            },
            {
              "$ref": "#/$defs/choiceD"
            },
            {
              "$ref": "#/$defs/choiceE"
            }
          ]
        },
        "shuffleChoices": {
          "type": "boolean",
          "description": "Whether choices should be shuffled when presented"
        },
        "learningObjectiveIds": {
          "type": "array",
          "description": "One or more learning objectives covered by this question",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^LO[1-9][0-9]*$"
          }
        },
        "correctAnswers": {
          "type": "array",
          "description": "One or more correct answer keys",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["A", "B", "C", "D", "E"]
          }
        },
        "locations": {
          "type": "array",
          "description": "One or more supporting references for this question, such as books, articles, or webpages",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/location"
          }
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Difficulty rating from 1 to 5"
        },
        "points": {
          "type": "integer",
          "minimum": 1,
          "description": "Point value awarded for a correct answer"
        },
        "explanation": {
          "type": "string",
          "description": "Optional explanation for the correct answer(s)"
        },
        "imageAssetIds": {
          "type": "array",
          "description": "Optional question-level image assets stored in the active .quizpool project.",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 2,
                "maxItems": 2
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 3,
                "maxItems": 3
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 4,
                "maxItems": 4
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 5,
                "maxItems": 5
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E"]
                }
              }
            }
          }
        }
      ]
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "text"],
      "properties": {
        "key": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "E"]
        },
        "text": {
          "type": "string",
          "description": "Choice text. Inline LaTeX is supported with [math]...[/math]."
        }
      }
    },
    "choiceA": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "A"
            }
          }
        }
      ]
    },
    "choiceB": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "B"
            }
          }
        }
      ]
    },
    "choiceC": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "C"
            }
          }
        }
      ]
    },
    "choiceD": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "D"
            }
          }
        }
      ]
    },
    "choiceE": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "E"
            }
          }
        }
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Optional source citation or title, such as a book, article, site, or webpage title"
        },
        "chapter": {
          "type": "string",
          "description": "Optional chapter or higher-level locator, e.g. Chapter 3"
        },
        "section": {
          "type": "string",
          "description": "Optional section or subsection locator"
        },
        "page": {
          "type": ["integer", "string"],
          "description": "Optional page number, page range, or similar locator"
        },
        "url": {
          "type": "string",
          "description": "Optional URL for a webpage or online source"
        },
        "reference": {
          "type": "string",
          "description": "Optional free-text note such as paragraph, figure, table, or other details"
        }
      }
    }
  }
}
