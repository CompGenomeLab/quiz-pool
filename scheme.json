{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/quiz-pool.schema.json",
  "title": "Quiz Pool",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "learningObjectives", "questions"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Name of the quiz pool"
    },
    "description": {
      "type": "string",
      "description": "Optional description of the quiz pool"
    },
    "learningObjectives": {
      "type": "array",
      "description": "Master list of one or more learning objectives",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/learningObjective"
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "learningObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^LO[1-9][0-9]*$"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "question",
        "choices",
        "shuffleChoices",
        "learningObjectiveIds",
        "correctAnswers",
        "bookLocations",
        "points",
        "difficulty"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the question"
        },
        "question": {
          "type": "string",
          "description": "Question text. Inline LaTeX is supported with [math]...[/math]."
        },
        "choices": {
          "type": "array",
          "description": "Contiguous answer choices labeled from A up to at most E",
          "minItems": 2,
          "maxItems": 5,
          "prefixItems": [
            {
              "$ref": "#/$defs/choiceA"
            },
            {
              "$ref": "#/$defs/choiceB"
            },
            {
              "$ref": "#/$defs/choiceC"
            },
            {
              "$ref": "#/$defs/choiceD"
            },
            {
              "$ref": "#/$defs/choiceE"
            }
          ]
        },
        "shuffleChoices": {
          "type": "boolean",
          "description": "Whether choices should be shuffled when presented"
        },
        "learningObjectiveIds": {
          "type": "array",
          "description": "One or more learning objectives covered by this question",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^LO[1-9][0-9]*$"
          }
        },
        "correctAnswers": {
          "type": "array",
          "description": "One or more correct answer keys",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["A", "B", "C", "D", "E"]
          }
        },
        "bookLocations": {
          "type": "array",
          "description": "One or more relevant places in the book for this question",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/bookLocation"
          }
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Difficulty rating from 1 to 5"
        },
        "points": {
          "type": "integer",
          "minimum": 1,
          "description": "Point value awarded for a correct answer"
        },
        "explanation": {
          "type": "string",
          "description": "Optional explanation for the correct answer(s)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 2,
                "maxItems": 2
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 3,
                "maxItems": 3
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 4,
                "maxItems": 4
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "choices": {
                "minItems": 5,
                "maxItems": 5
              }
            }
          },
          "then": {
            "properties": {
              "correctAnswers": {
                "items": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E"]
                }
              }
            }
          }
        }
      ]
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "text"],
      "properties": {
        "key": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "E"]
        },
        "text": {
          "type": "string",
          "description": "Choice text. Inline LaTeX is supported with [math]...[/math]."
        }
      }
    },
    "choiceA": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "A"
            }
          }
        }
      ]
    },
    "choiceB": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "B"
            }
          }
        }
      ]
    },
    "choiceC": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "C"
            }
          }
        }
      ]
    },
    "choiceD": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "D"
            }
          }
        }
      ]
    },
    "choiceE": {
      "allOf": [
        {
          "$ref": "#/$defs/choice"
        },
        {
          "properties": {
            "key": {
              "const": "E"
            }
          }
        }
      ]
    },
    "bookLocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chapter"],
      "properties": {
        "chapter": {
          "type": "string",
          "description": "Chapter reference, e.g. Chapter 3"
        },
        "section": {
          "type": "string",
          "description": "Optional section reference"
        },
        "page": {
          "type": ["integer", "string"],
          "description": "Optional page number or page range"
        },
        "reference": {
          "type": "string",
          "description": "Optional free-text note about the book location"
        }
      }
    }
  }
}
